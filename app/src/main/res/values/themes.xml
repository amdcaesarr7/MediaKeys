<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MediaKeys" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>

        <!-- Primary Accent -->
        <item name="colorPrimary">@color/neon_accent</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Widget.MediaKeys.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.MediaKeys.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="useMaterialThemeColors">true</item>
    </style>
</resources>
